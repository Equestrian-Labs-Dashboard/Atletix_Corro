name: Build data and deploy GitHub Pages

on:
  workflow_dispatch:
  schedule:
    # Automatic Shopify refresh every 2 days at 08:00 UTC.
    - cron: '0 8 */2 * *'
  push:
    branches: [ main ]

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: pages
  cancel-in-progress: false

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: '20'
      - name: Build Shopify data
        env:
          SHOPIFY_STORE: ${{ secrets.SHOPIFY_STORE }}
          SHOPIFY_TOKEN: ${{ secrets.SHOPIFY_TOKEN }}
          SHOPIFY_API_VERSION: ${{ vars.SHOPIFY_API_VERSION || '2024-01' }}
          ATLETIX_UNIT_COGS: ${{ vars.ATLETIX_UNIT_COGS || '89' }}
          ATLETIX_INITIAL_STOCK: ${{ vars.ATLETIX_INITIAL_STOCK || '100' }}
          ATLETIX_STOCK_RECEIVED_DATE: ${{ vars.ATLETIX_STOCK_RECEIVED_DATE || '2025-12-26' }}
          ATLETIX_SKU: ${{ vars.ATLETIX_SKU || 'ATLETIX60' }}
        run: npm run build:data
      - name: Configure Pages
        uses: actions/configure-pages@v5
      - name: Upload artifact
        uses: actions/upload-pages-artifact@v3
        with:
          path: public
  deploy:
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    runs-on: ubuntu-latest
    needs: build
    steps:
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
